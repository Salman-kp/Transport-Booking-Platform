# Server
PORT=8083
GRPC_PORT=9092
ENV=development

# Database
DB_URL="host=localhost port=5432 user=postgres dbname=bus_service sslmode=disable"
RUN_SEED_ON_BOOT=false

# Redis
REDIS_URL=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# gRPC Services Address Bindings
PAYMENT_SERVICE_ADDR=localhost:9093

# QR Code
QR_PUBLIC_BASE_URL=http://localhost:8080/api/qr/generate
QR_SIGNING_SECRET=change_me_for_prod

# Security Secrets & Salts
PNR_SALT=salt123

# Business TTL & Expiry Constraints (Minutes/Seconds)
BOOKING_EXPIRY_MINUTES=10
SEAT_LOCK_MINUTES=10
PRICING_ENGINE_INTERVAL_MINUTES=10
GPS_LOCATION_TTL_SECONDS=90